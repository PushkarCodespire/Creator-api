{
  "dashboard": {
    "id": null,
    "title": "Creator Platform - Application Metrics",
    "tags": ["nodejs", "api", "performance"],
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 0,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "API Response Time",
        "type": "graph",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, method, route))",
            "legendFormat": "{{method}} {{route}} 95th percentile"
          },
          {
            "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, method, route))",
            "legendFormat": "{{method}} {{route}} median"
          }
        ],
        "xaxis": {
          "mode": "time"
        },
        "yaxes": [
          {
            "format": "s",
            "label": "Response Time"
          }
        ]
      },
      {
        "id": 2,
        "title": "Requests per Second",
        "type": "graph",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "sum(rate(http_requests_total[5m])) by (method, route)",
            "legendFormat": "{{method}} {{route}}"
          }
        ],
        "xaxis": {
          "mode": "time"
        },
        "yaxes": [
          {
            "format": "reqps",
            "label": "Requests/second"
          }
        ]
      },
      {
        "id": 3,
        "title": "Error Rate",
        "type": "graph",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "sum(rate(http_request_duration_seconds_count{status=\"5..\"}[5m])) by (method, route) / sum(rate(http_request_duration_seconds_count[5m])) by (method, route) * 100"
            "legendFormat": "{{method}} {{route}} error %"
          }
        ],
        "xaxis": {
          "mode": "time"
        },
        "yaxes": [
          {
            "format": "percent",
            "label": "Error Rate %"
          }
        ]
      },
      {
        "id": 4,
        "title": "Active Connections",
        "type": "stat",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "nodejs_active_handles_total",
            "legendFormat": "Active Handles"
          }
        ],
        "options": {
          "orientation": "auto",
          "textMode": "auto"
        }
      },
      {
        "id": 5,
        "title": "Memory Usage",
        "type": "graph",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "nodejs_heap_size_total_bytes",
            "legendFormat": "Heap Total"
          },
          {
            "expr": "nodejs_heap_size_used_bytes",
            "legendFormat": "Heap Used"
          },
          {
            "expr": "nodejs_external_memory_bytes",
            "legendFormat": "External Memory"
          }
        ],
        "xaxis": {
          "mode": "time"
        },
        "yaxes": [
          {
            "format": "bytes",
            "label": "Memory"
          }
        ]
      },
      {
        "id": 6,
        "title": "Event Loop Lag",
        "type": "graph",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "nodejs_eventloop_lag_mean_seconds",
            "legendFormat": "Mean Lag"
          },
          {
            "expr": "nodejs_eventloop_lag_max_seconds",
            "legendFormat": "Max Lag"
          }
        ],
        "xaxis": {
          "mode": "time"
        },
        "yaxes": [
          {
            "format": "s",
            "label": "Time"
          }
        ]
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    }
  }
}